{
  "name": "devtoolbox-mcp",
  "version": "1.0.0",
  "description": "MCP server providing 25+ developer tools — JSON formatting, encoding, hashing, UUID, JWT, and more. All processing runs locally.",
  "main": "dist/index.js",
  "bin": {
    "devtools-mcp": "dist/index.js"
  },
  "type": "module",
  "scripts": {
    "build": "tsc",
    "postbuild": "echo '#!/usr/bin/env node' | cat - dist/index.js > /tmp/devtools-mcp-shebang.js && mv /tmp/devtools-mcp-shebang.js dist/index.js && chmod +x dist/index.js",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "developer-tools",
    "json-formatter",
    "base64",
    "hash",
    "uuid",
    "jwt",
    "claude",
    "ai-tools"
  ],
  "author": "EZARK Consulting Inc.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Rih0z/devtools-mcp"
  },
  "homepage": "https://usedevtools.com",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "tsx": "^4.7.0",
    "vitest": "^1.6.0",
    "@types/node": "^20.0.0"
  },
  "files": [
    "dist/",
    "README.md"
  ]
}
